{
  "name": "quietcut-clone",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/build-electron.cjs && concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build && node scripts/build-electron.cjs",
    "start": "electron .",
    "lint": "eslint ."
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wavesurfer.js": "^7.9.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "esbuild": "^0.25.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "fs-extra": "^11.3.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "wait-on": "^7.2.0"
  }
}
